{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Frontend (npm run dev 1st)",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "supraland_parser.py",
            "type": "debugpy",
            "request": "launch",
            "program": "supraland_parser.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceRoot}\\scripts",
            // When debugging supraland_parser.py the -s option specifies source data. For -v it's the
            // game root, for most other options its the place the game data has been extracted to.
            // Customise for your own setup and whichever option you want to debug
            //"args": "-g sw -d ..\\public\\data -s D:\\SteamLibrary\\steamapps\\common\\Supraworld -v"
            "args": "-g sw -d ..\\public\\data -s ..\\source\\sw -m"
        },
        {
            "name": "rendericons.js",
            "type": "node",
            "request": "launch",
            "program": "rendericons.js",
            "console": "integratedTerminal",
            "cwd": "${workspaceRoot}\\scripts",
            "args": ["-g", "all", "-d", "..\\public\\data", "-i", "..\\public\\img\\markers", "-o", "..\\public\\img\\rendered", "-l", "trace"]
        },
        {
            "name": "dumpsavestrings.js",
            "type": "node",
            "request": "launch",
            "program": "dumpsavestrings.js",
            "console": "integratedTerminal",
            "cwd": "${workspaceRoot}\\scripts",
            "args": ["-n", "1", "-l", "trace"]
        },
        {
            "name": "dumpsavefile.js",
            "type": "node",
            "request": "launch",
            "program": "dumpsavefile.js",
            "console": "integratedTerminal",
            "cwd": "${workspaceRoot}\\scripts",
            "args": ["--game", "siu", "-f", "..\\source\\siu\\SIUComplete.sav"]
        },
        {
            "name": "mergemarkers.mjs",
            "type": "node",
            "request": "launch",
            "program": "mergemarkers.mjs",
            "console": "integratedTerminal",
            "cwd": "${workspaceRoot}\\scripts",
            "args": [""]
        },
        {
            "name": "Node: Current File",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "args": [ "" ] //"-g", "sw", "-s", "GreenFirstRun"]//"$(command:PickArgs)"
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "args": "-g sw -d ..\\public\\data -s ..\\source\\sw -m"    // ${command:pickArgs}"
        },
        {
            "name": "Vite DEV server",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "runtimeExecutable": "npx",
            "runtimeArgs": [ "vite", "dev" ],
            "type": "node",
            "env": { "NO_COLOR": "1" },
            "serverReadyAction": {
                "killOnServerStop": true,
                "pattern": "Local:   http://localhost:([0-9]+)/",
                "uriFormat": "http://localhost:%s",
                "action":"openExternally"
            }
        }
    ]
}