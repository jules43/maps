{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Frontend Debug (npm run dev 1st)",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Debug rendericons.js",
            "type": "node",
            "request": "launch",
            "program": "rendericons.js",
            "console": "integratedTerminal",
            "cwd": "${workspaceRoot}\\scripts",
            "args": ["-g", "all", "-d", "..\\public\\data", "-i", "..\\public\\img\\markers", "-o", "..\\public\\img\\rendered", "-l", "trace"]
        },
        {
            "name": "Debug supraland_parser.py",
            "type": "debugpy",
            "request": "launch",
            "program": "supraland_parser.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceRoot}\\scripts",
            "args": "-g sw -d ..\\public\\data -s ..\\source\\sw -m"
        },
        {
            "name": "Node Debug: Current File",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "args": [ "" ] //"-g", "sw", "-s", "GreenFirstRun"]//"$(command:PickArgs)"
        },
        {
            "name": "Python Debug: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "args": "-g sw -d ..\\public\\data -s ..\\source\\sw -m"    // ${command:pickArgs}"
        },
        {
            "name": "Launch Vite DEV server",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "runtimeExecutable": "npx",
            "runtimeArgs": [ "vite", "dev" ],
            "type": "node",
            "env": { "NO_COLOR": "1" },
            "serverReadyAction": {
                "killOnServerStop": true,
                "pattern": "Local:   http://localhost:([0-9]+)/",
                "uriFormat": "http://localhost:%s",
                "action":"openExternally"
            }
        }
    ]
}