{
  "name": "supramaps",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "call scripts/shellstartup.cmd",
    "predev": "node scripts/rendericons.js",
    "dev": "vite",
    "prebuild": "node scripts/rendericons.js",
    "build": "vite build",
    "prepreview": "node scripts/rendericons.js && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "prettier-check": "prettier . --check",
    "flake8": "uvx flake8 .",
    "black-check": "uvx black --check .",
    "check-all": "npm run lint && npm run prettier-check && npm run flake8 && npm run black-check",
    "prettier": "prettier . --write",
    "black": "uvx black .",
    "format-all": "npm run prettier && npm run black",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "deploy-gh-pages": "npm run check-all && npm run test && node scripts/deploy-gh-pages.mjs deploy",
    "deploy-watch": "node scripts/deploy-gh-pages.mjs watch"
  },
  "dependencies": {
    "@fortawesome/react-fontawesome": "^3.3.1",
    "classnames": "^2.5.1",
    "leaflet": "^1.9.4",
    "leaflet.fullscreen": "^5.3.1",
    "playwright": "^1.60.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "readline-sync": "^1.4.10"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "canvas": "^3.2.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "path2d": "^0.3.1",
    "prettier": "3.8.3",
    "vite": "^8.0.4"
  }
}
